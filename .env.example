# =========================================================================
# VideoHostingBot Configuration Template
# =========================================================================
# Copy this file to '.env' and fill in your actual settings.
# Do NOT commit the '.env' file to your Git repository!
# =========================================================================

# 1. Telegram Bot Token (obtained from @BotFather in Telegram)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ

# 2. Public domain or IP (managed via Nginx Proxy Manager)
# This URL is used to generate direct streaming links for SLCamera.
# Make sure it matches your public domain configured in NPM (with http:// or https://)
APP_EXTERNAL_URL=https://your-domain.com

# 3. Database Configurations
# (Optional: customize if you want to change the database credentials)
POSTGRES_PASSWORD=postgres_secure_password
SPRING_DATASOURCE_PASSWORD=postgres_secure_password

# 4. Telegram Whitelist (comma-separated Telegram User IDs)
# If empty, anyone can use the bot. If set, only listed user IDs can upload.
# You can find your user ID using bots like @userinfobot or @raw_data_bot.
TELEGRAM_WHITELIST=123456789,987654321

